+    async with db(True) as conn:
+        async with await conn.execute(
+            t"""
+                UPDATE changeset
+                SET closed_at = statement_timestamp(), updated_at = DEFAULT
+                WHERE closed_at IS NULL AND (
+                    updated_at < statement_timestamp() - {CHANGESET_IDLE_TIMEOUT} OR
+                    (updated_at >= statement_timestamp() - {CHANGESET_IDLE_TIMEOUT} AND
+                    created_at < statement_timestamp() - {CHANGESET_OPEN_TIMEOUT})
+                )
+                RETURNING id, user_id, tags
+            """
+        ) as r:
+            rows = await r.fetchall()
+
+    rowcount = len(rows)
+    if not rowcount:
+        return
+
+    logging.debug('Closed %d inactive changesets', rowcount)
+
+    users = {
+        user['id']: user
+        for user in await UserQuery.find_by_ids([
+            user_id for _, user_id, _ in rows if user_id is not None
+        ])
+    }
+
+    for changeset_id, user_id, tags in rows:
+        if user_id is None:
+            continue
+        user = users.get(user_id)
+        if user is None:
+            logging.warning(
+                'Skipping note auto-close for changeset %d with missing user %d',
+                changeset_id,
+                user_id,
+            )
+            continue
+        await _close_changeset_notes(changeset_id, user, tags)
+
+
+def _note_closures_from_changeset_tags(tags: dict[str, str]) -> list[_NoteClosure]:
+    raw_note_ids = tags.get('closes:note')
+    if not raw_note_ids:
+        return []
+
+    default_comment = (
+        tags['closes:note:comment']
+        if 'closes:note:comment' in tags
+        else tags.get('comment', '')
     )
 
-    if rowcount:
-        logging.debug('Closed %d inactive changesets', rowcount)
+    closures: list[_NoteClosure] = []
+    seen: set[NoteId] = set()
+    for raw_part in raw_note_ids.split(';'):
+        part = raw_part.strip()
+        if not part.isdecimal():
+            continue
+
+        note_id = NoteId(int(part))
+        if note_id <= 0 or note_id in seen:
+            continue
+
+        comment = tags.get(f'closes:note:{note_id}:comment', default_comment)
+        closures.append(_NoteClosure(note_id, comment))
+        seen.add(note_id)
+
+    return closures
+
+
+async def _close_changeset_notes(
+    changeset_id: ChangesetId, user: User, tags: dict[str, str]
+):
+    closures = _note_closures_from_changeset_tags(tags)
+    if not closures:
+        return
+
+    with auth_context(user):
+        for closure in closures:
+            closed = await NoteService.close_if_open(
+                closure.note_id, closure.comment
+            )
+            if not closed:
+                logging.debug(
+                    'Skipping unavailable note %d close from changeset %d',
+                    closure.note_id,
+                    changeset_id,
+                )
 
 
