 Standards-Version: 4.1.4
-Homepage: https://github.com/wu-emma/bitgesell
+Homepage: https://github.com/BitgesellOfficial/bitgesell
 
 Package: bitgesell
 Architecture: any
diff --git a/debian.minimal/copyright b/debian.minimal/copyright
index 7235ef128..7c60277c7 100644
--- a/debian.minimal/copyright
+++ b/debian.minimal/copyright
@@ -1,6 +1,6 @@
 Format: https://www.debian.org/doc/packaging-manuals/copyright-format/1.0/
 Upstream-Name: bitgesell
-Source: https://github.com/wu-emma/bitgesell
